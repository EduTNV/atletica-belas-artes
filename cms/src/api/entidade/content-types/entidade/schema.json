{
  "kind": "collectionType",
  "collectionName": "entidades",
  "info": {
    "singularName": "entidade",
    "pluralName": "entidades",
    "displayName": "Entidade"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "nome": {
      "type": "string",
      "required": true
    },
    "descricao": {
      "type": "text"
    },
    "cor": {
      "type": "string"
    },
    "logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "membros": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::membro-entidade.membro-entidade",
      "mappedBy": "entidade"
    }
  }
}
